# ---------------- Docker Image Tags ----------------
PORTAINER_IMAGE_TAG=portainer/portainer-ce:latest
TRAEFIK_IMAGE_TAG=traefik:latest
DOCKER_API_VERSION=1.44

# ---------------- Hostnames ----------------
# Replace with your actual domain names
PORTAINER_FRONTEND_HOSTNAME=portainer.yourdomain.com
TRAEFIK_HOSTNAME=traefik.yourdomain.com

# ---------------- Traefik / Let's Encrypt ----------------
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_ACME_EMAIL=your-email@yourdomain.com

# Traefik Dashboard Basic Auth configuration.
# Generate the bcrypt hash using: echo $(htpasswd -nB username) | sed -e 's/\$/\$\$/g'
# Note the double dollar signs ($$) required for docker-compose parsing.
# Below is a default placeholder (admin / admin). CHANGE this in production.
TRAEFIK_BASIC_AUTH=admin:$$2y$$05$$sR0eN/1aA95sN2W0UvC.2ed30s/q6L5b9mU0z9a5R6Y3bC5dE8eG.
